<?xml version="1.0" encoding="utf-8"?>
<CommandTable xmlns="http://schemas.microsoft.com/VisualStudio/2005-10-18/CommandTable">
  <Extern href="stdidcmd.h" />
  <Extern href="vsshlids.h" />

  <Commands package="guidGhostTextPackage">
    <Groups>
      <Group guid="guidGhostTextCmdSet" id="GhostTextGroup" priority="0x0600">
        <Parent guid="guidSHLMainMenu" id="IDM_VS_MENU_TOOLS" />
      </Group>
    </Groups>

    <Menus>
      <Menu guid="guidGhostTextCmdSet" id="GhostTextMenu" priority="0x0100" type="Menu">
        <Parent guid="guidGhostTextCmdSet" id="GhostTextGroup" />
        <Strings>
          <ButtonText>re:code</ButtonText>
        </Strings>
      </Menu>
    </Menus>

    <Buttons>
      <Button guid="guidGhostTextCmdSet" id="GenerateCompletionCommand" priority="0x0100" type="Button">
        <Parent guid="guidGhostTextCmdSet" id="GhostTextMenu" />
        <Strings>
          <ButtonText>補完を生成</ButtonText>
        </Strings>
      </Button>

      <Button guid="guidGhostTextCmdSet" id="ToggleAutoCompletionCommand" priority="0x0110" type="Button">
        <Parent guid="guidGhostTextCmdSet" id="GhostTextMenu" />
        <Strings>
          <ButtonText>自動補完を切り替え</ButtonText>
        </Strings>
      </Button>

      <Button guid="guidGhostTextCmdSet" id="OpenSettingsCommand" priority="0x0120" type="Button">
        <Parent guid="guidGhostTextCmdSet" id="GhostTextMenu" />
        <Strings>
          <ButtonText>設定を開く</ButtonText>
        </Strings>
      </Button>

      <Button guid="guidGhostTextCmdSet" id="ShowDiagnosticsCommand" priority="0x0130" type="Button">
        <Parent guid="guidGhostTextCmdSet" id="GhostTextMenu" />
        <Strings>
          <ButtonText>診断を表示</ButtonText>
        </Strings>
      </Button>
    </Buttons>

  </Commands>

  <Symbols>
    <GuidSymbol name="guidGhostTextPackage" value="{8069B8EC-D030-4EE5-8087-D8836B9B782D}" />
