      <IDSymbol name="GhostTextMenu" value="0x1030" />
      <IDSymbol name="GenerateCompletionCommand" value="0x0100" />
      <IDSymbol name="ToggleAutoCompletionCommand" value="0x0101" />
      <IDSymbol name="OpenSettingsCommand" value="0x0102" />
      <IDSymbol name="ShowDiagnosticsCommand" value="0x0103" />
    </GuidSymbol>
  </Symbols>
</CommandTable>
